@* // INTEGRATION NOTE
   // Render this partial with either:
   // 1. A model of IReadOnlyList<COEPD.SalesFunnelSystem.Application.DTOs.Funnel3DStageDto>, or
   // 2. ViewBag.FunnelStageCounts containing serializable objects shaped like { stage, count, hexColor }.
   // Example usage:
   // @await Html.PartialAsync("_FunnelChart3D", Model.FunnelStages)
   // or
   // @{ ViewBag.FunnelStageCounts = new[] { new { stage = "Visitor", count = 1200 }, ... }; }
   // This partial is CDN-only and needs no bundler. *@
@using System.Text.Json
@using COEPD.SalesFunnelSystem.Application.DTOs
@model IReadOnlyList<Funnel3DStageDto>?
@{
    var componentId = $"funnel3d-{Guid.NewGuid():N}";
    var fallbackStageData = new List<Funnel3DStageDto>
    {
        new() { Stage = "Visitor", Count = 1480 },
        new() { Stage = "Lead", Count = 620 },
        new() { Stage = "Demo Booked", Count = 214 },
        new() { Stage = "Converted", Count = 88 }
    };
    var viewBagStageJson = ViewBag.FunnelStageCountsJson as string;
    var stageData = Model?.Any() == true
        ? Model
        : !string.IsNullOrWhiteSpace(viewBagStageJson)
            ? JsonSerializer.Deserialize<List<Funnel3DStageDto>>(viewBagStageJson, new JsonSerializerOptions(JsonSerializerDefaults.Web)) ?? fallbackStageData
            : (ViewBag.FunnelStageCounts as IReadOnlyList<Funnel3DStageDto>) ?? fallbackStageData;

    var chartJson = JsonSerializer.Serialize(stageData, new JsonSerializerOptions(JsonSerializerDefaults.Web));
}

<section class="funnel3d-card" id="@componentId">
    <div class="funnel3d-header">
        <div>
            <span class="funnel3d-eyebrow">3D Funnel Visualization</span>
            <h2>Stage volume, depth, and conversion at a glance</h2>
            <p>Hover each section to inspect raw volume and stage-to-stage conversion performance.</p>
        </div>
        <div class="funnel3d-summary">
            <span>Stages: @stageData.Count</span>
            <span>Total Visitors: @(stageData.FirstOrDefault()?.Count ?? 0)</span>
        </div>
    </div>

    <div class="funnel3d-viewport-wrap">
        <div class="funnel3d-viewport" data-funnel-canvas></div>
        <aside class="funnel3d-legend" data-funnel-legend>
            @for (var i = 0; i < stageData.Count; i++)
            {
                var previous = i == 0 ? 0 : stageData[i - 1].Count;
                var conversion = previous <= 0 ? 100m : Math.Round(stageData[i].Count * 100m / previous, 1);
                <div class="funnel3d-legend-item">
                    <span class="funnel3d-legend-stage">@stageData[i].Stage</span>
                    <strong>@stageData[i].Count</strong>
                    <small>@conversion% from previous stage</small>
                </div>
            }
        </aside>
        <div class="funnel3d-tooltip" data-funnel-tooltip></div>
    </div>
</section>

<style>
    #@componentId {
        --funnel-surface: rgba(255, 255, 255, 0.92);
        --funnel-border: rgba(15, 23, 42, 0.08);
        --funnel-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
        --funnel-text: var(--text-primary, #14213d);
        --funnel-muted: var(--text-secondary, #64748b);
        --funnel-accent: var(--primary, #0f766e);
        position: relative;
        border: 1px solid var(--funnel-border);
        border-radius: 28px;
        background:
            radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 28%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96));
        box-shadow: var(--funnel-shadow);
        overflow: hidden;
    }

    #@componentId .funnel3d-header {
        display: flex;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.5rem 1.5rem 0;
        color: var(--funnel-text);
    }

    #@componentId .funnel3d-header h2 {
        margin: 0.35rem 0 0.45rem;
        font-size: clamp(1.3rem, 2vw, 1.9rem);
        line-height: 1.1;
    }

    #@componentId .funnel3d-header p,
    #@componentId .funnel3d-summary,
    #@componentId .funnel3d-legend-item small {
        color: var(--funnel-muted);
    }

    #@componentId .funnel3d-eyebrow {
        display: inline-flex;
        align-items: center;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.12);
        color: var(--funnel-accent);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    #@componentId .funnel3d-summary {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: center;
        gap: 0.45rem;
        font-size: 0.92rem;
        white-space: nowrap;
    }

    #@componentId .funnel3d-viewport-wrap {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(250px, 0.8fr);
        gap: 1rem;
        padding: 1rem 1.5rem 1.5rem;
        min-height: 520px;
    }

    #@componentId .funnel3d-viewport {
        min-height: 460px;
        border-radius: 22px;
        background:
            linear-gradient(180deg, rgba(226, 232, 240, 0.2), rgba(226, 232, 240, 0)),
            radial-gradient(circle at top, rgba(255, 255, 255, 0.9), rgba(226, 232, 240, 0.28));
        border: 1px solid rgba(148, 163, 184, 0.2);
    }

    #@componentId .funnel3d-legend {
        display: grid;
        gap: 0.75rem;
        align-content: start;
    }

    #@componentId .funnel3d-legend-item {
        padding: 1rem;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: rgba(255, 255, 255, 0.76);
        backdrop-filter: blur(10px);
    }

    #@componentId .funnel3d-legend-stage {
        display: block;
        margin-bottom: 0.35rem;
        color: var(--funnel-text);
        font-weight: 700;
    }

    #@componentId .funnel3d-tooltip {
        position: absolute;
        z-index: 5;
        min-width: 210px;
        padding: 0.85rem 1rem;
        border-radius: 16px;
        background: rgba(15, 23, 42, 0.96);
        color: #f8fafc;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.3);
        pointer-events: none;
        opacity: 0;
        transform: translate3d(0, 10px, 0);
        transition: opacity 140ms ease, transform 140ms ease;
    }

    #@componentId .funnel3d-tooltip.is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }

    #@componentId .funnel3d-tooltip strong {
        display: block;
        margin-bottom: 0.35rem;
        font-size: 0.98rem;
    }

    #@componentId .funnel3d-tooltip span {
        display: block;
        font-size: 0.88rem;
        color: rgba(226, 232, 240, 0.86);
    }

    @@media (max-width: 980px) {
        #@componentId .funnel3d-header,
        #@componentId .funnel3d-viewport-wrap {
            grid-template-columns: 1fr;
            display: grid;
        }

        #@componentId .funnel3d-summary {
            align-items: flex-start;
        }
    }
</style>

<script>
    (function () {
        const root = document.getElementById("@componentId");
        if (!root || root.dataset.initialized === "true") {
            return;
        }

        root.dataset.initialized = "true";

        const stageData = @Html.Raw(chartJson);
        const canvasHost = root.querySelector("[data-funnel-canvas]");
        const tooltip = root.querySelector("[data-funnel-tooltip]");

        function ensureScript(src) {
            return new Promise((resolve, reject) => {
                const existing = Array.from(document.scripts).find(script => script.src === src);
                if (existing) {
                    if (existing.dataset.loaded === "true") {
                        resolve();
                        return;
                    }

                    existing.addEventListener("load", () => resolve(), { once: true });
                    existing.addEventListener("error", reject, { once: true });
                    return;
                }

                const script = document.createElement("script");
                script.src = src;
                script.async = true;
                script.addEventListener("load", () => {
                    script.dataset.loaded = "true";
                    resolve();
                }, { once: true });
                script.addEventListener("error", reject, { once: true });
                document.head.appendChild(script);
            });
        }

        function hexToColor(hex, fallback) {
            try {
                return new THREE.Color(hex || fallback);
            } catch {
                return new THREE.Color(fallback);
            }
        }

        function createLabelSprite(text) {
            const canvas = document.createElement("canvas");
            canvas.width = 512;
            canvas.height = 128;
            const context = canvas.getContext("2d");
            context.clearRect(0, 0, canvas.width, canvas.height);
            context.fillStyle = "rgba(255,255,255,0.92)";
            context.fillRect(0, 18, canvas.width, 92);
            context.strokeStyle = "rgba(15,23,42,0.18)";
            context.lineWidth = 4;
            context.strokeRect(2, 20, canvas.width - 4, 88);
            context.fillStyle = "#0f172a";
            context.font = "700 42px Inter, Arial, sans-serif";
            context.textAlign = "center";
            context.textBaseline = "middle";
            context.fillText(text, canvas.width / 2, canvas.height / 2 + 2);

            const texture = new THREE.CanvasTexture(canvas);
            texture.needsUpdate = true;
            const material = new THREE.SpriteMaterial({ map: texture, transparent: true });
            const sprite = new THREE.Sprite(material);
            sprite.scale.set(4.8, 1.2, 1);
            return sprite;
        }

        function positionTooltip(event, html) {
            tooltip.innerHTML = html;
            tooltip.classList.add("is-visible");
            const bounds = root.getBoundingClientRect();
            const left = Math.min(bounds.width - tooltip.offsetWidth - 16, Math.max(16, event.clientX - bounds.left + 14));
            const top = Math.min(bounds.height - tooltip.offsetHeight - 16, Math.max(16, event.clientY - bounds.top + 14));
            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
        }

        function hideTooltip() {
            tooltip.classList.remove("is-visible");
        }

        Promise.all([
            ensureScript("https://cdn.jsdelivr.net/npm/three@0.128.0/build/three.min.js")
        ]).then(() => {
            const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
            renderer.setSize(canvasHost.clientWidth, canvasHost.clientHeight);
            canvasHost.appendChild(renderer.domElement);

            const scene = new THREE.Scene();
            scene.background = null;

            const camera = new THREE.PerspectiveCamera(40, canvasHost.clientWidth / canvasHost.clientHeight, 0.1, 1000);
            camera.position.set(0, 4.2, 15);

            const ambientLight = new THREE.AmbientLight(0xffffff, 1.15);
            scene.add(ambientLight);

            const topLight = new THREE.DirectionalLight(0xffffff, 1.45);
            topLight.position.set(4, 10, 8);
            scene.add(topLight);

            const fillLight = new THREE.PointLight(0x7dd3fc, 0.9, 50);
            fillLight.position.set(-6, 3, 8);
            scene.add(fillLight);

            const group = new THREE.Group();
            scene.add(group);

            const maxCount = Math.max(...stageData.map(item => item.count), 1);
            const minCount = Math.min(...stageData.map(item => item.count), maxCount);
            const topRadius = 4.5;
            const bottomRadius = 1.3;
            const segmentHeight = 2.2;
            const totalHeight = stageData.length * segmentHeight;
            const raycaster = new THREE.Raycaster();
            const pointer = new THREE.Vector2();
            const meshes = [];

            stageData.forEach((stage, index) => {
                const progress = stageData.length === 1 ? 0 : index / (stageData.length - 1);
                const radiusTop = topRadius - ((topRadius - bottomRadius) * progress);
                const radiusBottom = topRadius - ((topRadius - bottomRadius) * ((index + 1) / stageData.length));
                const normalized = maxCount === minCount ? 0.5 : (stage.count - minCount) / (maxCount - minCount);
                const hue = 8 + (normalized * 110);
                const defaultColor = `hsl(${Math.round(hue)}, 78%, ${44 + ((1 - normalized) * 8)}%)`;
                const color = hexToColor(stage.hexColor, defaultColor);
                const geometry = new THREE.CylinderGeometry(radiusBottom, radiusTop, segmentHeight, 64, 1, false);
                const material = new THREE.MeshPhysicalMaterial({
                    color,
                    roughness: 0.28,
                    metalness: 0.1,
                    transparent: true,
                    opacity: 0.96,
                    clearcoat: 0.45,
                    clearcoatRoughness: 0.18
                });

                const mesh = new THREE.Mesh(geometry, material);
                mesh.position.y = (totalHeight / 2) - (segmentHeight * index) - (segmentHeight / 2);
                mesh.userData = {
                    stage: stage.stage,
                    count: stage.count,
                    conversion: index === 0
                        ? 100
                        : Number(((stage.count / Math.max(stageData[index - 1].count, 1)) * 100).toFixed(1)),
                    baseColor: color.clone()
                };

                const edgeLines = new THREE.LineSegments(
                    new THREE.EdgesGeometry(geometry),
                    new THREE.LineBasicMaterial({ color: 0xffffff, opacity: 0.36, transparent: true })
                );
                mesh.add(edgeLines);
                group.add(mesh);
                meshes.push(mesh);

                const label = createLabelSprite(stage.stage);
                label.position.set(0, mesh.position.y, radiusTop + 3.25);
                group.add(label);
            });

            const basePlatform = new THREE.Mesh(
                new THREE.CircleGeometry(5.3, 64),
                new THREE.MeshBasicMaterial({ color: 0x94a3b8, transparent: true, opacity: 0.12 })
            );
            basePlatform.rotation.x = -Math.PI / 2;
            basePlatform.position.y = -(totalHeight / 2) - 1.5;
            scene.add(basePlatform);

            group.rotation.x = -0.16;
            group.rotation.y = -0.26;

            function onPointerMove(event) {
                const rect = renderer.domElement.getBoundingClientRect();
                pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
                pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

                raycaster.setFromCamera(pointer, camera);
                const intersections = raycaster.intersectObjects(meshes, false);

                meshes.forEach(mesh => {
                    mesh.material.emissive?.setHex(0x000000);
                    mesh.scale.set(1, 1, 1);
                });

                if (!intersections.length) {
                    hideTooltip();
                    root.style.cursor = "default";
                    return;
                }

                const target = intersections[0].object;
                target.material.emissive = new THREE.Color(0x15334a);
                target.scale.set(1.02, 1.02, 1.02);
                root.style.cursor = "pointer";

                positionTooltip(event, `
                    <strong>${target.userData.stage}</strong>
                    <span>Count: ${target.userData.count.toLocaleString()}</span>
                    <span>Conversion from previous stage: ${target.userData.conversion}%</span>
                `);
            }

            renderer.domElement.addEventListener("pointermove", onPointerMove);
            renderer.domElement.addEventListener("pointerleave", () => {
                hideTooltip();
                root.style.cursor = "default";
                meshes.forEach(mesh => mesh.scale.set(1, 1, 1));
            });

            const resizeObserver = new ResizeObserver(() => {
                const width = canvasHost.clientWidth;
                const height = canvasHost.clientHeight;
                camera.aspect = width / height;
                camera.updateProjectionMatrix();
                renderer.setSize(width, height);
            });

            resizeObserver.observe(canvasHost);

            let animationFrameId = 0;

            function animate() {
                animationFrameId = window.requestAnimationFrame(animate);
                group.rotation.y += 0.0035;
                renderer.render(scene, camera);
            }

            animate();

            root.addEventListener("remove", () => {
                window.cancelAnimationFrame(animationFrameId);
                resizeObserver.disconnect();
                renderer.dispose();
            }, { once: true });
        }).catch(error => {
            canvasHost.innerHTML = `<div style="padding:1rem;color:#b91c1c;">Unable to load the 3D funnel renderer. ${error.message}</div>`;
        });
    })();
</script>
